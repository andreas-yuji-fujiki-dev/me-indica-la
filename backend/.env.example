# Application
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meindicala?schema=public

# Security
JWT_ACCESS_SECRET=your-strong-access-secret-here-change-in-production
JWT_ACCESS_EXPIRES_IN=900 # 15 minutes in seconds
JWT_REFRESH_SECRET=your-strong-refresh-secret-here-change-in-production
JWT_REFRESH_EXPIRES_IN=604800 # 7 days in seconds

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_TTL=60000 # 1 minute
RATE_LIMIT_LIMIT=100 # requests per minute

# Security Headers
HELMET_CONTENT_SECURITY_POLICY=default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: https:

# Application Secrets
SESSION_SECRET=your-session-secret-here-change-in-production
COOKIE_SECRET=your-cookie-secret-here-change-in-production

# Email (for future implementation)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# File Uploads (if implemented)
UPLOAD_MAX_SIZE=5242880 # 5MB
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp